<?xml version="1.0" standalone="yes"?>
<!--
  Polycom master config for {{.MAC}} (tenant: {{.Tenant.Slug}}).
  Generated by SIP Platform control-plane at {{.Now.Format "2006-01-02T15:04:05Z"}}.
  This is a self-contained config — Polycom phones load this single file
  on boot via their per-MAC URL (e.g. {{.MAC | upper}}.cfg). No other
  feature files are referenced; everything is inline.

  Tested generations: VVX (250/350/450), Edge E series, Trio with sysweb/UCS 6+.
-->
<APPLICATION
    APP_FILE_PATH=""
    CONFIG_FILES=""
    MISC_FILES=""
    LOG_FILE_DIRECTORY=""
    OVERRIDES_DIRECTORY=""
    CONTACTS_DIRECTORY=""
    LICENSE_DIRECTORY=""
    USER_PROFILES_DIRECTORY=""
    CALL_LISTS_DIRECTORY=""
    COREFILE_DIRECTORY="">

  <!-- Identity -->
  <device device.set="1">
    <device.dhcp device.dhcp.bootSrvUseOpt.set="1" device.dhcp.bootSrvUseOpt="0"/>
    <device.prov device.prov.serverType.set="1" device.prov.serverType="HTTPS"
                 device.prov.serverName.set="1" device.prov.serverName="{{.Provision.PublicHost}}"/>
  </device>

  {{range .Lines}}
  <!-- Line {{.LineNumber}}: ext {{.Extension}} ({{.Label}}) -->
  <reg reg.{{.LineNumber}}.displayName="{{.DisplayName}}"
       reg.{{.LineNumber}}.label="{{.Label}}"
       reg.{{.LineNumber}}.address="{{.Username}}@{{.SIPDomain}}"
       reg.{{.LineNumber}}.auth.userId="{{.Username}}"
       reg.{{.LineNumber}}.auth.password="{{.Password}}"
       reg.{{.LineNumber}}.type="private"
       reg.{{.LineNumber}}.lineKeys="1"
       reg.{{.LineNumber}}.protocol.SIP="1"
       reg.{{.LineNumber}}.server.1.address="{{$.SIP.Proxy}}"
       reg.{{.LineNumber}}.server.1.port="{{$.SIP.ProxyPort}}"
       reg.{{.LineNumber}}.server.1.transport="{{polycomTransport $.SIP.Transport}}"
       reg.{{.LineNumber}}.server.1.expires="{{$.SIP.RegisterExp}}"
       reg.{{.LineNumber}}.outboundProxy.address="{{$.SIP.Proxy}}"
       reg.{{.LineNumber}}.outboundProxy.port="{{$.SIP.ProxyPort}}"
       reg.{{.LineNumber}}.outboundProxy.transport="{{polycomTransport $.SIP.Transport}}"/>
  {{end}}

  <!-- Codecs (narrow list; widen per-tenant later) -->
  <voice.codecPref
      voice.codecPref.G711_Mu="1"
      voice.codecPref.G711_A="2"
      voice.codecPref.G722="3"
      voice.codecPref.Opus="4"/>

  <!-- Standard dial plan: 3- to 11-digit destinations, # to send -->
  <dialplan dialplan.digitmap="[2-9]xx|*xx|9xxxxxxxxxx|+xxxxxxxxxxx"/>

  <!-- Time / NTP -->
  <tcpIpApp tcpIpApp.sntp.address="pool.ntp.org" tcpIpApp.sntp.gmtOffset="0"/>

  <!-- Local feature defaults -->
  <feature feature.messaging.enabled="1"
           feature.urlDialing.enabled="0"
           feature.directedCallPickup.enabled="1"
           feature.callPark.enabled="1"/>

</APPLICATION>
