# Copy to .env and fill in. Do NOT commit .env.

# Postgres
POSTGRES_DB=sipplatform
POSTGRES_USER=sip
POSTGRES_PASSWORD=change_me_in_dev

# Redis (no password in dev)
REDIS_URL=redis://redis:6379/0

# Control plane
CONTROL_PLANE_ADMIN_ADDR=:8080
CONTROL_PLANE_PROVISIONING_ADDR=:8443
CONTROL_PLANE_LOG_LEVEL=info

# Provisioning TLS (dev self-signed; replace with Let's Encrypt in prod)
PROVISIONING_TLS_CERT=/etc/control-plane/tls/cert.pem
PROVISIONING_TLS_KEY=/etc/control-plane/tls/key.pem

# FreeSWITCH ESL — control plane subscribes to call events
ESL_HOST=freeswitch
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# Kamailio listen addresses (host networking in prod; bridge ports in dev)
KAMAILIO_SIP_UDP_PORT=5060
KAMAILIO_SIP_TCP_PORT=5060
KAMAILIO_SIP_TLS_PORT=5061
KAMAILIO_WSS_PORT=7443

# FreeSWITCH RTP port range (keep small in dev for bridge networking; expand in prod)
FS_RTP_START=16384
FS_RTP_END=16484

# Public IP that FreeSWITCH advertises in outbound SDP (c= line + Contact).
# Must be the IP carriers like CallCentric actually see for our traffic, NOT
# the container/private/LAN IP. Examples:
#   Production VPS:   EXT_SIP_IP=203.0.113.45    (your static public IP)
#   Behind cloud NAT: EXT_SIP_IP=203.0.113.45    (the Elastic / floating IP)
#   AWS w/ EIP:       EXT_SIP_IP=<your EIP>
# Leave blank in dev — FreeSWITCH falls back to STUN auto-discovery
# (stun:stun.freeswitch.org) which works through Docker + home NAT but
# breaks when the ISP-assigned address changes.
EXT_SIP_IP=
EXT_RTP_IP=

# Carrier (Phase 2)
# CallCentric credentials live in freeswitch/conf/vars-local.xml (gitignored).
# Copy freeswitch/conf/vars-local.xml.example → vars-local.xml and edit.
FS_EXTERNAL_SIP_PORT=5070

# Public hostname for provisioning URLs handed to phones (Phase 1+)
PROVISIONING_PUBLIC_HOST=provision.example.local

# Public SIP address handed to provisioned phones as their outbound proxy.
# In dev this can be the host IP or a hostname that resolves to it.
SIP_PUBLIC_HOST=sip.example.local
SIP_PUBLIC_PORT=5060
SIP_PUBLIC_TRANSPORT=udp

# SMTP relay for voicemail-to-email (Wave 2.5). Leave SMTP_HOST empty to
# skip email delivery; voicemail still lands on disk + in voicemail_messages.
# Common configs:
#   AWS SES: smtp.us-east-1.amazonaws.com:587, STARTTLS=true, user/pass from SES SMTP creds
#   Mailgun: smtp.mailgun.org:587, STARTTLS=true
#   Postmark: smtp.postmarkapp.com:587, STARTTLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=PBX <pbx@example.com>
SMTP_STARTTLS=true

# Manufacturer RPS / true ZTP (Task #10). Each vendor needs its own portal
# account; leave any of these empty to fall back to LogOnly (records the
# attempt without calling the vendor). Yealink/Grandstream/Cisco use the
# same pattern — adapters will appear here as they're written.
#
# Polycom ZTP — pre-create a "profile" at https://ztp.poly.com that points
# at https://<your provisioning host>/ as the redirect URL.
POLYCOM_ZTP_API_BASE=https://api.ztp.poly.com
POLYCOM_ZTP_API_TOKEN=
POLYCOM_ZTP_PROFILE_ID=

# Phase 4.0 auth: bootstrap super-admin API token. Inserted on startup
# only if api_tokens is empty. Format: sip_<48 hex chars>. Generate with:
#   echo "sip_$(openssl rand -hex 24)"
# Hand to admins / scripts as: `Authorization: Bearer sip_...`
BOOTSTRAP_API_TOKEN=
