<?xml version="1.0"?>
<configuration name="modules.conf" description="Modules">
  <modules>
    <!-- Logging -->
    <load module="mod_console"/>
    <load module="mod_logfile"/>

    <!-- Event Socket Library (control plane connects via ESL) -->
    <load module="mod_event_socket"/>

    <!-- XML providers -->
    <load module="mod_xml_curl"/>      <!-- dynamic dialplan from Go control plane -->

    <!-- Core SIP/RTP -->
    <load module="mod_sofia"/>
    <load module="mod_loopback"/>

    <!-- Dialplan + tools -->
    <load module="mod_dialplan_xml"/>
    <load module="mod_dptools"/>
    <load module="mod_commands"/>
    <load module="mod_expr"/>
    <load module="mod_db"/>
    <load module="mod_hash"/>
    <load module="mod_esf"/>
    <load module="mod_fsv"/>

    <!-- Codecs -->
    <load module="mod_g711"/>          <!-- PCMU / PCMA -->
    <load module="mod_g722"/>
    <load module="mod_opus"/>
    <load module="mod_b64"/>

    <!-- Audio / file -->
    <load module="mod_sndfile"/>
    <load module="mod_native_file"/>
    <load module="mod_tone_stream"/>
    <load module="mod_local_stream"/>

    <!-- Languages / TTS (Phase 3 IVR) -->
    <load module="mod_say_en"/>

    <!-- Phase 3 Wave 2: voicemail -->
    <load module="mod_voicemail"/>

    <!-- Phase 3 Wave 4: call queues / ACD -->
    <load module="mod_callcenter"/>

    <!-- Phase 3+ (later waves):
    <load module="mod_fifo"/>
    <load module="mod_conference"/>
    <load module="mod_av"/>
    -->
  </modules>
</configuration>
