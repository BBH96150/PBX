<?xml version="1.0"?>
<configuration name="event_socket.conf" description="Event Socket">
  <settings>
    <!-- Control plane subscribes from another container; bind on all interfaces. -->
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${default_password_esl:-ClueCon}"/>
    <!-- `local-net` is defined in autoload_configs/acl.conf.xml.
         Allows RFC1918 + loopback — fine for in-cluster control-plane
         and fs_cli on localhost. Tighten in production. -->
    <param name="apply-inbound-acl" value="local-net"/>
  </settings>
</configuration>
