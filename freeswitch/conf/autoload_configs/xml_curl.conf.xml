<?xml version="1.0"?>
<configuration name="xml_curl.conf" description="cURL XML Gateway">
  <bindings>
    <!-- All dialplan lookups go to the Go control plane.
         The control plane returns FreeSWITCH dialplan XML per-call. -->
    <binding name="dialplan">
      <param name="gateway-url" value="http://control-plane:8080/v1/freeswitch/dialplan" bindings="dialplan"/>
      <param name="gateway-credentials" value=""/>
      <param name="auth-scheme" value="basic"/>
      <param name="disable-100-continue" value="true"/>
      <param name="timeout" value="2000"/>
      <param name="connect-timeout" value="1000"/>
    </binding>

    <!-- Directory lookups (mod_voicemail uses these to fetch vm-password,
         vm-mailto, etc. for each user). We do NOT use the directory for SIP
         auth — Kamailio handles that — but voicemail needs user records. -->
    <binding name="directory">
      <param name="gateway-url" value="http://control-plane:8080/v1/freeswitch/directory" bindings="directory"/>
      <param name="auth-scheme" value="basic"/>
      <param name="disable-100-continue" value="true"/>
      <param name="timeout" value="2000"/>
      <param name="connect-timeout" value="1000"/>
    </binding>

    <!-- Configuration lookups (mod_ivr asks for ivr.conf at runtime). -->
    <binding name="configuration">
      <param name="gateway-url" value="http://control-plane:8080/v1/freeswitch/configuration" bindings="configuration"/>
      <param name="auth-scheme" value="basic"/>
      <param name="disable-100-continue" value="true"/>
      <param name="timeout" value="2000"/>
      <param name="connect-timeout" value="1000"/>
    </binding>
  </bindings>
</configuration>
