<?xml version="1.0"?>
<!--
  Per-deployment local vars for FreeSWITCH (gitignored when copied to
  vars-local.xml). Fill in carrier credentials here; vars.xml includes
  this file via X-PRE-PROCESS.

  Copy to vars-local.xml and edit; do NOT commit the populated file.
-->
<include>
  <!-- CallCentric SIP credentials.
       Get these from https://my.callcentric.com → Settings → SIP. -->
  <X-PRE-PROCESS cmd="set" data="cc_account_username=1777XXXXXXX"/>
  <X-PRE-PROCESS cmd="set" data="cc_account_password=replace-me"/>
  <X-PRE-PROCESS cmd="set" data="cc_realm=callcentric.com"/>
  <X-PRE-PROCESS cmd="set" data="cc_proxy=callcentric.com"/>

  <!-- ESL listener password. event_socket.conf.xml reads
       $${default_password_esl:-ClueCon}; set a STRONG value here in prod and
       the SAME value as ESL_PASSWORD in .env (the control-plane connects with
       that). Leaving this unset falls back to the well-known default ClueCon —
       fine for local dev, NOT for production. -->
  <X-PRE-PROCESS cmd="set" data="default_password_esl=replace-with-strong-secret"/>
</include>
