<?xml version="1.0"?>
<include>
  <!-- Global FreeSWITCH vars used across configs. -->

  <X-PRE-PROCESS cmd="set" data="sound_prefix=/usr/share/freeswitch/sounds/en/us/callie"/>
  <X-PRE-PROCESS cmd="set" data="default_password=hardly-used-because-kamailio-auths"/>

  <!-- Default codecs offered/accepted. Keep narrow; widen per-tenant later. -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=OPUS,G722,PCMU,PCMA"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=OPUS,G722,PCMU,PCMA"/>

  <!-- RTP port range (matches docker-compose FS_RTP_START/END). -->
  <X-PRE-PROCESS cmd="set" data="rtp_start_port=16384"/>
  <X-PRE-PROCESS cmd="set" data="rtp_end_port=16484"/>

  <!-- Internal SIP profile binds here; Kamailio sends to freeswitch:5080. -->
  <X-PRE-PROCESS cmd="set" data="internal_sip_port=5080"/>
  <X-PRE-PROCESS cmd="set" data="internal_ssl_port=5081"/>

  <!-- Trust list: source IPs allowed to inject calls without SIP digest auth.
       In docker this is the bridge subnet that Kamailio sits on. -->
  <X-PRE-PROCESS cmd="set" data="domain=$${local_ip_v4}"/>
  <X-PRE-PROCESS cmd="set" data="domain_name=$${local_ip_v4}"/>

  <!-- External SIP profile (Phase 2, PSTN-facing). -->
  <X-PRE-PROCESS cmd="set" data="external_sip_port=5070"/>
  <X-PRE-PROCESS cmd="set" data="external_ssl_port=5071"/>

  <!-- Carrier credentials live in vars-local.xml (gitignored).
       Copy vars-local.xml.example to vars-local.xml and edit. -->
  <X-PRE-PROCESS cmd="include" data="vars-local.xml"/>
</include>
